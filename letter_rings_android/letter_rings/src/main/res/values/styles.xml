<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="material_button_style" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="backgroundTint">@color/background_tint_material_button</item>
        <item name="android:textColor">@color/text_color_material_button</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/consola</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="material_slider_font_style" parent="SlideToActView">
        <item name="android:fontFamily">@font/consola</item>
    </style>

    <style name="radio_button_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:fontFamily">@font/consola</item>
        <item name="android:padding">4dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:textSize">20sp</item>
        <item name="buttonTint">@color/button_tint_radio_button</item>
        <item name="android:textColor">@color/text_color_radio_button</item>
    </style>

    <style name="switch_style">
        <item name="trackTint">@color/track_tint_material_switch</item>
        <item name="thumbTint">@color/thumb_tint_material_switch</item>
        <item name="android:enabled">true</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:fontFamily">@font/consola</item>
        <item name="android:showText">false</item>
        <item name="android:textSize">20sp</item>
        <item name="android:padding">4dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>
</resources>