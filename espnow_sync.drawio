        <mxCell id="XdOzOzR_qPLhWqYeDEd4-24" value="NOT SYNCED" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=20;" parent="XdOzOzR_qPLhWqYeDEd4-26" vertex="1">
