        </mxCell>
        <mxCell id="XdOzOzR_qPLhWqYeDEd4-25" value="&lt;font&gt;Each device measures time between sending and receiving messages. The measured time is exchanged with the next message.&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Adding the times measured on both devices produces loop+latency*2, here: 50+5*2=60.&lt;/span&gt;&lt;div&gt;&lt;font&gt;&lt;b&gt;The device having measured the shorter time adds extra-delay.&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontStyle=0;fontSize=19;" parent="XdOzOzR_qPLhWqYeDEd4-26" vertex="1">
          <mxGeometry y="30" width="280" height="300" as="geometry" />
        </mxCell>
        <mxCell id="XdOzOzR_qPLhWqYeDEd4-33" value="" style="endArrow=oval;html=1;rounded=0;startArrow=oval;startFill=1;endFill=1;strokeColor=#CCCC00;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=11;fontColor=default;labelBackgroundColor=default;" parent="1" edge="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
