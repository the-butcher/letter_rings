        <mxCell id="XdOzOzR_qPLhWqYeDEd4-62" value="Times still add up to 60.&lt;div&gt;&lt;b&gt;The device having measured the shorter time adds more extra-delay.&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;br style=&quot;font-size: 20px;&quot;&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontStyle=0;fontSize=19;" parent="XdOzOzR_qPLhWqYeDEd4-60" vertex="1">
